SIMULATION_START_TIME=2026-06-20T00:00:00Z
GAME_SPEED=300

# Airport capacity and per-guest processing.
# EU_GATES / ALL_GATES — number of EU and non-EU (all-passport) gates.
# PROCESSING_TIME_EU / PROCESSING_TIME_ALL — processing time per guest in game seconds.
EU_GATES=3
ALL_GATES=2
PROCESSING_TIME_EU=300
PROCESSING_TIME_ALL=600

# Each *_SERVICE_URL may be a comma-separated list of instances; a pool with
# more than one URL is round-robined by the gateway, e.g.
# PARROT_SERVICE_URL=http://parrot-a:3003,http://parrot-b:3003
AIRPORT_SERVICE_URL=http://airport:3001
HOTEL_SERVICE_URL=http://hotel:3000
BROADCAST_SERVICE_URL=http://broadcast:3002
CRAB_SERVICE_URL=http://crab:3004

PARROT_SERVICE_URL=http://parrot:3003,http://parrot-b:3003

# LLM_BASE_URL=http://192.168.100.4:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen3.5:4b

LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY="API_KEY"
LLM_MODEL=meta-llama/llama-3.1-8b-instruct

LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=600
LLM_TOP_P=1.0

# Comma-separated profanity stop list; unset = curated built-in default from parrot/config.py
# PROFANITY_WORDS=damn,hell

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Gateway cache and rate-limit settings (all off by default).
# GATEWAY_CACHE_TTL — response cache TTL for safe GETs (Go duration, e.g. 5s). Empty/0 = off.
GATEWAY_CACHE_TTL=0
# GATEWAY_RATE_LIMIT — max requests per window per client. 0 = off. Set high (e.g. 600) when live.
GATEWAY_RATE_LIMIT=0
# GATEWAY_RATE_WINDOW — rate-limit window (Go duration). Used only when the limit > 0.
GATEWAY_RATE_WINDOW=1m

# Frontend (VITE_*). Compose reads these from this file for the frontend image.
VITE_GATEWAY_URL=http://localhost:8000
VITE_MOCK=false
# Frontend admin login (Observer mode). Empty = "Admin login is not configured".
# Keep this in sync with ADMIN_SECRET below so UI admins can also call the admin API.
VITE_ADMIN_PASSCODE=admin123
VITE_TRAFFIC_GENERATOR=on
VITE_PARROT_CHAT_COOLDOWN_MS=30000
VITE_SIMULATION_START_TIME=2026-06-20T00:00:00Z
VITE_GAME_SPEED=300

# Broadcast - leave the values as is for grading
FE_TOKEN=fe-token
HOTEL_TOKEN=hotel-token
BEACH_TOKEN=beach-token
AIRPORT_TOKEN=airport-token
PARROT_TOKEN=parrot-token

# Beach
DB_HOST=postgres
DB_PORT=5432
JDBC_URL=jdbc:postgresql://postgres:5432/beach
DB_NAME=beach
DB_USER=postgres
DB_PASSWORD=postgres
APP_PORT=8080

# Admin / service-to-service secrets
# ADMIN_SECRET: gates the beach activity add/remove API. Shared with the
#   frontend VITE_ADMIN_PASSCODE so a UI admin can also call the admin API.
# INTERNAL_SECRET: shared secret for trusted service-to-service calls
#   (sent as X-Internal-Key by the gateway, parrot, airport, etc.).
ADMIN_SECRET=admin123
INTERNAL_SECRET=admin123